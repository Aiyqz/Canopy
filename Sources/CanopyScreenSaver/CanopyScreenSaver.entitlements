<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Shared container with the Canopy app. Both targets must be signed with
         the SAME Team ID for this group to resolve; otherwise the saver can't
         read the rendered frames and shows its placeholder. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.pro.getcanopy.shared</string>
    </array>
</dict>
</plist>
